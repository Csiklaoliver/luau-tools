{
  "name": "luau-tools",
  "version": "0.1.0",
  "description": "Full Luau developer experience outside Roblox Studio — type checking, formatting, linting, and more.",
  "author": "csiklaoliver",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/csiklaoliver/luau-tools.git"
  },
  "bugs": {
    "url": "https://github.com/csiklaoliver/luau-tools/issues"
  },
  "homepage": "https://github.com/csiklaoliver/luau-tools#readme",
  "keywords": [
    "luau",
    "lua",
    "roblox",
    "type-checking",
    "lsp",
    "formatter",
    "linter"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "bin": {
    "luau-tools": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}
